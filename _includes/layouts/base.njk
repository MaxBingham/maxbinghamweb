<!doctype html>
<html lang="{{ metadata.language }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{% if title and page.url != "/" %}{{ title }} — {{ metadata.title }}{% else %}{{ metadata.title }}{% endif %}</title>
		<meta name="description" content="{{ description or metadata.description }}">
		<link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">
		<meta name="generator" content="{{ eleventy.generator }}">
		<meta name="color-scheme" content="light dark">

		<style>{% include "node_modules/simpledotcss/simple.min.css" %}</style>
		<style>{% include "css/custom.css" %}</style>
		<link rel="stylesheet" href="{% getBundleFileUrl "css" %}">

		<script type="module">{% include "node_modules/@zachleat/heading-anchors/heading-anchors.js" %}</script>
	</head>
	<body>
		<a href="#main" id="skip-link" class="visually-hidden">Skip to main content</a>

		<header class="site-header">
			<a class="wordmark" href="/" aria-label="Home">
				<span class="wordmark-name">Max Bingham</span>
				<span class="wordmark-dot" aria-hidden="true">·</span>
				<span class="wordmark-sub">personal site</span>
			</a>
			<nav aria-label="Primary">
				<ul class="nav">
				{%- for entry in collections.all | eleventyNavigation %}
					{%- if entry.key != "Home" %}
					<li class="nav-item"><a href="{{ entry.url }}"{% if entry.url == page.url %} aria-current="page"{% endif %}>{{ entry.title }}</a></li>
					{%- endif %}
				{%- endfor %}
				</ul>
			</nav>
		</header>

		{% if page.url != "/" %}
		<div class="page-title">
			<h1>{%- if title %}{{ title }}{%- else %}{{ metadata.title }}{%- endif %}</h1>
			{% if description %}<p class="page-description">{{ description }}</p>{% endif %}
		</div>
		{% endif %}

		<main id="main">
			<heading-anchors>
				{{ content | safe }}
			</heading-anchors>
		</main>

		<footer class="site-footer">
			<p>
				<a href="/">Home</a> ·
				<a href="/works/">Work</a> ·
				<a href="/visuals/">Visuals</a> ·
				<a href="/thoughts/">Thoughts</a> ·
				<a href="/cv/">CV</a> ·
				<a href="/feed/feed.xml">Atom</a>
			</p>
			<p>
				<a href="https://github.com/MaxBingham" rel="me">GitHub</a> ·
				<a href="https://www.linkedin.com/in/mjbinghamnikol" rel="me">LinkedIn</a> ·
				<a href="mailto:max.bingham-nikol@tum.de">Email</a>
			</p>
			<p class="muted">Built in Eleventy. Source on <a href="https://github.com/MaxBingham/maxbinghamweb">GitHub</a>. No trackers.</p>
		</footer>

		<script type="module" src="{% getBundleFileUrl "js" %}"></script>
	</body>
</html>
